# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database Configuration
# Get this from Supabase project settings -> Database -> Connection string (URI mode)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
# Note: Not used in Phase 0, but required for Phase 3+ (AI roles)
OPENAI_API_KEY=sk-your-openai-api-key-here
